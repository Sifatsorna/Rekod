<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Rekod.MainPage">

    <StackLayout>
        <Frame BackgroundColor="#2196F3"
               Padding="24"
               CornerRadius="0">
            <Label Text="Rekod"
                   HorizontalTextAlignment="Center"
                   TextColor="White"
                   FontSize="36" />
        </Frame>

        <ScrollView>
            <StackLayout x:Name="deckStack"
                         Margin="80, 0">
            </StackLayout>
        </ScrollView>

        <Button x:Name="CreateDeckButton"
                Text="Create Deck"
                Margin="80, 0"
                BackgroundColor="Coral"
                Clicked="OnDeckCreate" />
    </StackLayout>
</ContentPage>